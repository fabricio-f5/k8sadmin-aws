# ------------------------------------------------------------
# Configurações locais (usar os arquivos .example como base)
# ------------------------------------------------------------
root.hcl

# ------------------------------------------------------------
# Terraform
# ------------------------------------------------------------
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Terraform lock file (opcional versionar)
# Se quiser consistência de provider, COMENTE a linha abaixo
.terraform.lock.hcl

# ------------------------------------------------------------
# Terragrunt
# ------------------------------------------------------------
**/.terragrunt-cache/*
terragrunt-debug.tfvars.json

# ------------------------------------------------------------
# Variáveis sensíveis
# ------------------------------------------------------------
*.tfvars
*.tfvars.json
!*.tfvars.example

# ------------------------------------------------------------
# AWS / credenciais
# ------------------------------------------------------------
.aws/
*.pem
*.key

# ------------------------------------------------------------
# Ansible
# ------------------------------------------------------------
*.retry
inventory.ini
inventory.yaml
host_vars/
ansible/inventory/aws_ec2.yml

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log

# ------------------------------------------------------------
# IDEs / Editores
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------
# OS
# ------------------------------------------------------------
.DS_Store
Thumbs.db

# ------------------------------------------------------------
# Python (caso use automações/Ansible scripts)
# ------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
env/
venv/

# ------------------------------------------------------------
# Node (caso use frontend / tooling)
# ------------------------------------------------------------
node_modules/

# ------------------------------------------------------------
# Kubernetes (se gerar configs locais)
# ------------------------------------------------------------
.kube/
kubeconfig

ansible-env/